# E2E Test Environment Variables
#
# These values are used by Playwright's webServer.config and the db:seed script.
# They are set in playwright.config.ts webServer.env — this file is for reference only.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=rob-and-ana

# Relaxed rate limits for testing (100 failed logins per minute instead of default 5)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SEC=60
