# web-deploy-env
DOMAIN=yourdomain.com
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# agent-dev-env
BRAVE_API_KEY=your_brave_api_key

# Application (required — change admin password in production)
APP_NAME=Wedding
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Session encryption (required — must be unique per deployment, at least 32 chars)
SESSION_SECRET=replace-with-a-random-secret-string

# Rate limiting (optional — defaults: max 5 attempts per 60s window)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_MS=60000

# Media storage directory (optional — defaults to ./data/media)
# MEDIA_DIR=./data/media

# Database (optional — production default is file:/app/data/sqlite/prod.db)
# DATABASE_URL=file:/app/data/sqlite/prod.db
