{
  "name": "web-wedding-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.vitest.json",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:parallel && npm run test:e2e:serial",
    "test:e2e:parallel": "playwright test --project=parallel",
    "test:e2e:serial": "playwright test --project=serial",
    "test:e2e:ui": "playwright test --ui",
    "test:check": "npm run typecheck && npm run lint && npm test",
    "db:seed": "tsx scripts/db-seed.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "ffmpeg-static": "^5.3.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
